# X API credentials (Required)
X_API_KEY=
X_API_KEY_SECRET=
X_ACCESS_TOKEN=
X_ACCESS_TOKEN_SECRET=

# Optional AI provider
# - xai: xAI API (OpenAI-compatible endpoint)
# - claude_agent: Claude Agent SDK (Claude Code plan), with optional CLI fallback
AI_PROVIDER=xai
AI_API_KEY=
AI_BASE_URL=https://api.x.ai/v1
AI_MODEL=grok-3-latest
AI_TIMEOUT_SEC=60
CLAUDE_CLI_PATH=claude
CLAUDE_MAX_TURNS=4
CLAUDE_USE_CLI_FALLBACK=true

# Optional app defaults
DEFAULT_NUM_POSTS=5
DEFAULT_TEST_MODE=true
DEFAULT_SUBMIT_NOTES=false
DEFAULT_EVALUATE_BEFORE_SUBMIT=true
DEFAULT_MIN_CLAIM_OPINION_SCORE=0.55

# Feed language is fixed in code: post_selection=feed_lang:ja
